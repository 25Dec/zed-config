// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "title_bar": {
    "show_menus": false,
    "show_branch_icon": false
  },
  "vim": {
    "toggle_relative_line_numbers": true
  },
  "inline_code_actions": false,
  "current_line_highlight": "all",
  "cursor_blink": false,
  "text_rendering_mode": "platform_default",
  "prettier": {
  },
  "outline_panel": {
    "dock": "left",
    "indent_guides": {
      "show": "always"
    },
    "file_icons": true,
    "default_width": 300.0,
    "git_status": true
  },
  "ensure_final_newline_on_save": false,
  "remove_trailing_whitespace_on_save": false,
  "icon_theme": "Material Icon Theme",
  "git_panel": {
    "dock": "left",
    "show_count_badge": true,
    "file_icons": true,
    "tree_view": true,
    "sort_by_path": false,
    "status_style": "label_color"
  },
  "terminal": {
    "button": false,
    "font_family": "JetBrainsMono Nerd Font"
  },
  "buffer_font_family": "Intel One Mono",
  "enable_language_server": true,
  "agent": {
    "dock": "right",
    "model_parameters": []
  },
  "notification_panel": {
    "button": false
  },
  "preview_tabs": {
    
  },
  "search": {
    "button": false,
    "center_on_match": true
  },
  "inlay_hints": {
    "enabled": false
  },
  "use_on_type_format": false,
  "format_on_save": "off",
  "indent_guides": {
    "coloring": "indent_aware",
    "background_coloring": "disabled"
  },
  "minimap": {
    
  },
  "scrollbar": {
    "show": "auto",
    "axes": {
      "vertical": false,
      "horizontal": false
    }
  },
  "toolbar": {
    "code_actions": false,
    "agent_review": true,
    "selections_menu": true,
    "quick_actions": false,
    "breadcrumbs": false
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false
  },
  "disable_ai": true,
  "tab_bar": {
    "show": true,
    "show_pinned_tabs_in_separate_row": true,
    "show_tab_bar_buttons": true,
    "show_nav_history_buttons": false
  },
  "tabs": {
    "file_icons": true,
    "git_status": true
  },
  "debugger": {
    "button": false
  },
  "project_panel": {
    "dock": "left",
    "hide_root": false,
    "hide_hidden": false,
    "entry_spacing": "comfortable",
    "indent_guides": {
      "show": "always"
    },
    "bold_folder_labels": true,
    "git_status": true,
    "scrollbar": {
      "show": "auto"
    },
    "folder_icons": true,
    "button": false
  },
  "status_bar": {
    "show_active_file": false,
    "active_language_button": false,
    "cursor_position_button": false
  },
  "diagnostics": {
    "inline": {
      "enabled": true
    },
    "button": false
  },
  "colorize_brackets": true,
  "sticky_scroll": {
    "enabled": true
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "vim_mode": true,
  "base_keymap": "VSCode",
  "ui_font_size": 16.0,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Ayu Mirage",
  },
}
